{
  "name": "media-src",
  "version": "0.0.0",
  "private": "true",
  "scripts": {
    "start": "esbuild ./src/main.ts --bundle --watch --sourcemap --outfile=../media/dist/main.js",
    "build": "rm -rf ../media/dist; esbuild ./src/main.ts --bundle --minify --sourcemap --outfile=../media/dist/main.js",
    "test": "echo 'Unit tests are consolidated under vitest — run `npm test` from the repo root.' && exit 1",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_COVERAGE=1 playwright test"
  },
  "browserslist": "> 0%",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^14.14.41",
    "monocart-coverage-reports": "^2.12.12",
    "typescript": "^4.2.3"
  },
  "dependencies": {
    "esbuild": "^0.11.23",
    "vditor": "^3.11.2"
  }
}
